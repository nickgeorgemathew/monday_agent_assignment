# Copy this to .env and fill in your values

# Monday.com API Token (Account Settings > Developer > API Token v2)
MONDAY_API_TOKEN=your_monday_api_token_here

# Board IDs — get from the URL when viewing each board
# e.g. monday.com/boards/1234567890 → ID is 1234567890
MONDAY_DEALS_BOARD_ID=your_deals_board_id
MONDAY_WORK_ORDERS_BOARD_ID=your_work_orders_board_id

# Anthropic API Key — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key
